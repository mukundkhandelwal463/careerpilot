{
  "dashboard": {
    "id": null,
    "uid": "resume-screener-dash",
    "title": "AI Resume Screener - Monitoring Dashboard",
    "tags": ["resume-screener", "flask", "prometheus"],
    "timezone": "browser",
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Total HTTP Requests",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "targets": [
          {
            "expr": "http_requests_total",
            "legendFormat": "Total Requests",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20,
              "gradientMode": "scheme",
              "pointSize": 5,
              "showPoints": "auto"
            },
            "unit": "short"
          },
          "overrides": []
        }
      },
      {
        "id": 2,
        "title": "Resumes Analyzed",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "targets": [
          {
            "expr": "resumes_analyzed_total",
            "legendFormat": "Resumes",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 50 },
                { "color": "red", "value": 100 }
              ]
            },
            "unit": "short"
          },
          "overrides": []
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto",
          "textMode": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        }
      },
      {
        "id": 3,
        "title": "App Uptime",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "targets": [
          {
            "expr": "app_uptime_seconds",
            "legendFormat": "Uptime",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "blue", "value": null }
              ]
            },
            "unit": "s"
          },
          "overrides": []
        },
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "auto",
          "textMode": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        }
      },
      {
        "id": 4,
        "title": "Gemini AI API Calls vs Errors",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "targets": [
          {
            "expr": "gemini_calls_total",
            "legendFormat": "Gemini API Calls",
            "refId": "A"
          },
          {
            "expr": "gemini_errors_total",
            "legendFormat": "Gemini Errors",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 15,
              "gradientMode": "scheme",
              "pointSize": 5,
              "showPoints": "auto"
            },
            "unit": "short"
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Gemini Errors" },
              "properties": [
                { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
              ]
            }
          ]
        }
      },
      {
        "id": 5,
        "title": "Auth Activity (Logins & Registrations)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "targets": [
          {
            "expr": "auth_logins_total",
            "legendFormat": "Logins",
            "refId": "A"
          },
          {
            "expr": "auth_registrations_total",
            "legendFormat": "Registrations",
            "refId": "B"
          },
          {
            "expr": "summaries_generated_total",
            "legendFormat": "Summaries Generated",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 15,
              "gradientMode": "scheme",
              "pointSize": 5,
              "showPoints": "auto"
            },
            "unit": "short"
          },
          "overrides": []
        }
      }
    ],
    "schemaVersion": 38
  },
  "overwrite": true
}
